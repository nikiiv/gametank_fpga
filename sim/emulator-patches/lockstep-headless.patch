+//--- gametank_fpga lockstep patch: headless per-frame framebuffer dumps ---
+static FILE* lockstep_file = NULL;
+static long  lockstep_frames = 0;
+static long  lockstep_count = 0;
+// scripted input: GTE_LOCKSTEP_INPUT="flip:p1mask,flip:p1mask,..." (hex
+// masks in GamepadButtonMask layout); applied when the flip counter
+// reaches each entry, so both lockstep sides see identical stimulus.
+#include <vector>
+struct LockstepInput { long flip; unsigned mask; };
+static std::vector<LockstepInput> lockstep_inputs;
+static size_t lockstep_input_pos = 0;
+static void lockstep_init() {
+	const char* inp = getenv("GTE_LOCKSTEP_INPUT");
+	if(inp) {
+		const char* s = inp;
+		while(*s) {
+			long f = strtol(s, (char**)&s, 10);
+			if(*s == ':') s++;
+			unsigned m = (unsigned)strtoul(s, (char**)&s, 16);
+			lockstep_inputs.push_back({f, m});
+			if(*s == ',') s++;
+		}
+	}
+	const char* out = getenv("GTE_LOCKSTEP_OUT");
+	if(!out) return;
+	lockstep_file = fopen(out, "wb");
+	const char* n = getenv("GTE_LOCKSTEP_FRAMES");
+	lockstep_frames = n ? atol(n) : 60;
+}
